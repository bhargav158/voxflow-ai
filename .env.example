# VoxFlow — Environment Configuration Example
# Copy this file to `.env` and fill with your actual values.
#
# REQUIRED FOR BASIC APP START:
# - LLM_PROVIDER
# - At least one LLM key (recommended: GEMINI_API_KEY or OPENROUTER_API_KEY)
#
# REQUIRED FOR EMAIL INBOX ANALYSIS COMMANDS:
# - OPENROUTER_API_KEY
# - EMAIL_IMAP_HOST
# - EMAIL_ADDRESS
# - EMAIL_APP_PASSWORD
#
# REQUIRED FOR QDRANT RETRIEVAL + PERSISTENT MEMORY:
# - QDRANT_URL
# - QDRANT_API_KEY
# - GEMINI_API_KEY

# Core provider selection
LLM_PROVIDER=gemini

# LLM keys (set at least one)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# Voice (optional Vapi)
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=

# Qdrant / retrieval (required only if you want vector retrieval + memory)
QDRANT_URL=https://your-qdrant-instance-url
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=voxflow-kb
PYTHON_QDRANT_URL=http://127.0.0.1:8001

# Debug mode
DEBUG_MODE=false

# SMTP for real email sending action (optional)
SMTP_USER=
SMTP_PASS=

# Inbox reading and analysis (IMAP)
# Example for Gmail:
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
# EMAIL_IMAP_SECURE=true
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_SECURE=true
EMAIL_IMAP_MAILBOX=INBOX
EMAIL_ADDRESS=your_email@example.com
EMAIL_APP_PASSWORD=

# OpenRouter model for email analysis summarization
OPENROUTER_MODEL=google/gemma-3-27b-it:free
